---
import type { Locale } from '../i18n/utils';
import { t, localePath, getAlternateUrl } from '../i18n/utils';
import { FORTALEZA_URL } from '../config/links';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const altLocale: Locale = locale === 'es' ? 'en' : 'es';
const altUrl = getAlternateUrl(currentPath, altLocale);
---

<header
  class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-margin-mobile md:px-margin-desktop py-unit-4 bg-background border-b border-outline-variant"
  style="max-width:100vw"
>
  <a
    href={localePath('/', locale)}
    class="font-mono-label text-body-lg font-bold tracking-tighter text-primary hover:opacity-80 transition-opacity"
  >
    Harden.Tools
  </a>

  <nav class="hidden md:flex items-center gap-unit-8">
    <a
      href={localePath('/services', locale)}
      class="text-on-surface-variant font-mono-label hover:text-primary transition-colors duration-200"
    >
      {t(locale, 'nav.services')}
    </a>
    <a
      href={localePath('/philosophy', locale)}
      class="text-on-surface-variant font-mono-label hover:text-primary transition-colors duration-200"
    >
      {t(locale, 'nav.philosophy')}
    </a>
    <a
      href={localePath('/fortaleza', locale)}
      class="text-on-surface-variant font-mono-label hover:text-primary transition-colors duration-200"
    >
      {t(locale, 'nav.fortaleza')}
    </a>
    <a
      href={localePath('/contact', locale)}
      class="text-on-surface-variant font-mono-label hover:text-primary transition-colors duration-200"
    >
      {t(locale, 'nav.contact')}
    </a>
  </nav>

  <div class="flex items-center gap-unit-4">
    <a
      href={altUrl}
      class="font-mono-label text-xs text-on-surface-variant hover:text-primary transition-colors border border-outline-variant px-2 py-1"
      aria-label={`Switch to ${altLocale === 'en' ? 'English' : 'Español'}`}
    >
      {altLocale === 'en' ? 'EN' : 'ES'}
    </a>
    <a
      href={localePath('/contact', locale)}
      class="bg-primary text-on-primary font-mono-label px-unit-4 py-unit-2 rounded-lg hover:opacity-80 transition-all text-sm"
    >
      {t(locale, 'nav.get_started')}
    </a>
  </div>
</header>
