---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';
import SectionLabel from './SectionLabel.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<section class="px-margin-mobile md:px-margin-desktop py-16 bg-background">
  <div class="max-w-max-width mx-auto space-y-16">
    <!-- Cryptographic validation -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-unit-8">
      <div class="space-y-unit-4">
        <h2 class="font-headline-md text-headline-md text-primary tracking-tighter uppercase">
          {t(locale, 'fortaleza.crypto_section.title')}
        </h2>
        <p class="text-on-surface-variant text-body-lg">{t(locale, 'fortaleza.crypto_section.desc')}</p>
        <ul class="space-y-unit-2 font-mono-label text-on-surface">
          {
            ['feat1', 'feat2', 'feat3'].map((key) => (
              <li class="flex items-center gap-unit-2">
                <span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">
                  check_circle
                </span>
                {t(locale, `fortaleza.crypto_section.${key}`)}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="bg-surface-container border border-outline-variant p-unit-4 font-mono-code text-mono-code">
        <div class="flex items-center gap-unit-2 mb-unit-4">
          <span class="w-2 h-2 rounded-full bg-primary"></span>
          <span class="text-on-surface-variant text-xs">REPORT: HTTPS://API.HARDEN.TOOLS</span>
        </div>
        <div class="space-y-1 text-xs">
          {
            [
              ['Protocol', 'TLS 1.3', true],
              ['Cipher', 'ChaCha20-Poly1305', false],
              ['Expiry', '82 Days Remaining', false],
              ['DMARC', 'v=DMARC1; p=reject;', true],
            ].map(([label, value, highlight]) => (
              <div class="flex justify-between border-b border-outline-variant/30 py-1">
                <span class="text-on-surface-variant">{label}</span>
                <span class:list={[highlight ? 'text-primary font-bold' : 'text-on-surface']}>{value}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Kanban + AI Patch -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-unit-8 items-start">
      <div class="md:col-span-7 border border-outline-variant bg-surface-container p-unit-6 overflow-x-auto">
        <h3 class="font-mono-label text-on-surface mb-unit-6 text-xs">
          {t(locale, 'fortaleza.kanban.label').toUpperCase()}
        </h3>
        <div class="flex gap-unit-4 min-w-[560px]">
          <!-- Backlog -->
          <div class="flex-1 space-y-unit-4">
            <div class="flex items-center justify-between border-b border-outline-variant pb-unit-2">
              <span class="font-mono-label text-on-surface-variant text-[10px]">{t(locale, 'fortaleza.kanban.col_backlog')}</span>
              <span class="text-[9px] px-1 bg-outline-variant text-on-surface">4</span>
            </div>
            <div class="p-unit-3 bg-background border-l-2 border-error space-y-unit-1">
              <div class="text-[10px] font-bold text-error">{t(locale, 'fortaleza.kanban.severity_critical')}</div>
              <div class="text-xs text-on-surface">Exposed SSH Port</div>
              <div class="text-[9px] text-on-surface-variant font-mono-code">ID: CVE-2024-001</div>
            </div>
            <div class="p-unit-3 bg-background border-l-2 border-secondary space-y-unit-1">
              <div class="text-[10px] font-bold text-secondary">{t(locale, 'fortaleza.kanban.severity_high')}</div>
              <div class="text-xs text-on-surface">CORS Policy Gap</div>
              <div class="text-[9px] text-on-surface-variant font-mono-code">ID: CVE-2024-002</div>
            </div>
          </div>
          <!-- Remediating -->
          <div class="flex-1 space-y-unit-4">
            <div class="flex items-center justify-between border-b border-outline-variant pb-unit-2">
              <span class="font-mono-label text-on-surface-variant text-[10px]">{t(locale, 'fortaleza.kanban.col_remediating')}</span>
              <span class="text-[9px] px-1 bg-outline-variant text-on-surface">1</span>
            </div>
            <div class="p-unit-3 bg-background border-l-2 border-primary space-y-unit-1">
              <div class="text-[10px] font-bold text-primary">{t(locale, 'fortaleza.kanban.severity_info')}</div>
              <div class="text-xs text-on-surface">Subdomain Scan</div>
              <div class="text-[9px] text-on-surface-variant font-mono-code">ID: INTEL-004</div>
            </div>
          </div>
          <!-- Verified -->
          <div class="flex-1 space-y-unit-4 opacity-40">
            <div class="flex items-center justify-between border-b border-outline-variant pb-unit-2">
              <span class="font-mono-label text-on-surface-variant text-[10px]">{t(locale, 'fortaleza.kanban.col_verified')}</span>
              <span class="text-[9px] px-1 bg-outline-variant text-on-surface">12</span>
            </div>
          </div>
        </div>
      </div>

      <!-- AI Patch -->
      <div class="md:col-span-5 space-y-unit-6">
        <div>
          <h2 class="font-headline-md text-headline-md text-primary tracking-tighter uppercase mb-unit-4">
            {t(locale, 'fortaleza.ai_section.title')}
          </h2>
          <p class="text-on-surface-variant text-body-md">{t(locale, 'fortaleza.ai_section.desc')}</p>
          <p class="text-on-surface-variant text-xs font-mono-label mt-unit-2 opacity-60">
            {t(locale, 'fortaleza.ai_section.powered_by')}
          </p>
        </div>
        <div class="bg-surface-container-lowest border border-outline-variant p-unit-4 relative group">
          <div class="absolute top-4 right-4 text-on-surface-variant hover:text-primary cursor-pointer" title="Copy">
            <span class="material-symbols-outlined text-sm">content_copy</span>
          </div>
          <div class="font-mono-code text-primary mb-unit-4 flex items-center gap-unit-2 text-xs">
            <span class="material-symbols-outlined text-sm">auto_awesome</span>
            {t(locale, 'fortaleza.ai_section.label')}
          </div>
          <code class="block text-on-surface space-y-1 text-xs">
            <span class="text-on-surface-variant">{t(locale, 'fortaleza.ai_section.snippet_comment')}</span><br />
            <span class="text-secondary">aws</span> ec2 revoke-security-group-ingress \<br />
            &nbsp;&nbsp;--group-id sg-0492e \<br />
            &nbsp;&nbsp;--protocol tcp \<br />
            &nbsp;&nbsp;--port 22 \<br />
            &nbsp;&nbsp;--cidr 0.0.0.0/0
          </code>
        </div>
      </div>
    </div>
  </div>
</section>
