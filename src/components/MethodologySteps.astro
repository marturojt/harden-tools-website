---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';
import esData from '../i18n/es.json';
import enData from '../i18n/en.json';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const data = locale === 'es' ? esData : enData;
const steps = data.home.methodology.steps;
---

<section class="py-16 px-margin-mobile md:px-margin-desktop overflow-hidden">
  <div class="max-w-max-width mx-auto">
    <h2 class="font-headline-md text-headline-md mb-unit-8 text-center">{t(locale, 'home.methodology.title')}</h2>
    <div class="relative">
      <div class="absolute top-6 left-0 w-full h-px bg-outline-variant hidden md:block"></div>
      <div class="flex flex-col md:flex-row justify-between relative z-10 gap-unit-8">
        {
          steps.map((step) => (
            <div class="flex-1 flex flex-col items-center text-center">
              <div class="w-12 h-12 bg-background border border-primary flex items-center justify-center mb-unit-4 group hover:bg-primary transition-all duration-300 cursor-default">
                <span class="font-mono-code text-primary group-hover:text-background font-bold">{step.num}</span>
              </div>
              <h4 class="font-mono-label text-on-surface mb-unit-2">{step.name}</h4>
              <p class="font-body-md text-on-surface-variant text-sm px-unit-4">{step.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
