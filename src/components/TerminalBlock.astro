---
interface Props {
  title?: string;
  lines: string[];
  highlightFirst?: boolean;
  highlightLast?: boolean;
  warnLine?: number;
}
const { title = 'fortaleza@root: ~ /validation-stream', lines, highlightFirst = true, highlightLast = true, warnLine } = Astro.props;
---

<div class="border border-outline-variant bg-surface-container-lowest p-unit-4 shadow-2xl">
  <div class="flex items-center justify-between mb-unit-4 border-b border-outline-variant pb-unit-2">
    <span class="font-mono-label text-xs text-on-surface-variant">{title}</span>
    <div class="flex gap-1">
      <div class="w-3 h-3 rounded-full bg-error"></div>
      <div class="w-3 h-3 rounded-full bg-secondary"></div>
      <div class="w-3 h-3 rounded-full bg-primary"></div>
    </div>
  </div>
  <div class="font-mono-code text-mono-code text-on-surface-variant leading-relaxed space-y-1">
    {
      lines.map((line, i) => {
        const isFirst = i === 0 && highlightFirst;
        const isLast = i === lines.length - 1 && highlightLast;
        const isWarn = warnLine !== undefined && i === warnLine;
        return (
          <div
            class:list={[
              isFirst && 'text-primary',
              isLast && 'text-primary',
              isWarn && 'text-secondary',
              !isFirst && !isLast && !isWarn && 'text-on-surface-variant',
            ]}
          >
            {line}
          </div>
        );
      })
    }
    <div class="animate-pulse text-primary">_</div>
  </div>
</div>
