---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';
import { FORTALEZA_SIGNUP, FORTALEZA_PRICING } from '../config/links';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<section class="px-margin-mobile md:px-margin-desktop py-16 border-t border-outline-variant">
  <div class="max-w-max-width mx-auto flex flex-col items-center text-center space-y-unit-6">
    <h2 class="font-display-lg text-[36px] md:text-display-lg text-on-surface tracking-tighter uppercase">
      {t(locale, 'fortaleza.cta.title')}
    </h2>
    <p class="font-body-lg text-on-surface-variant max-w-2xl">{t(locale, 'fortaleza.cta.desc')}</p>

    <div class="flex flex-col md:flex-row gap-unit-4 w-full md:w-auto">
      <a
        href={FORTALEZA_SIGNUP}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-primary text-on-primary px-unit-12 py-unit-4 font-mono-label font-bold text-lg hover:opacity-90 transition-all flex items-center justify-center gap-2"
      >
        {t(locale, 'fortaleza.cta.cta_scan')}
        <span class="material-symbols-outlined text-base">open_in_new</span>
      </a>
      <a
        href={FORTALEZA_PRICING}
        target="_blank"
        rel="noopener noreferrer"
        class="border border-outline-variant text-on-surface px-unit-12 py-unit-4 font-mono-label text-lg hover:bg-surface-container transition-all flex items-center justify-center gap-2"
      >
        {t(locale, 'fortaleza.cta.cta_pricing')}
        <span class="material-symbols-outlined text-base text-primary">open_in_new</span>
      </a>
    </div>

    <p class="font-mono-label text-xs text-on-surface-variant">{t(locale, 'fortaleza.cta.trial_note')}</p>
  </div>
</section>
