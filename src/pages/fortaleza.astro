---
import BaseLayout from '../layouts/BaseLayout.astro';
import FortalezaScanners from '../components/FortalezaScanners.astro';
import FortalezaCompliance from '../components/FortalezaCompliance.astro';
import DashboardMockup from '../components/DashboardMockup.astro';
import KanbanMockup from '../components/KanbanMockup.astro';
import ExternalCTA from '../components/ExternalCTA.astro';
import TerminalBlock from '../components/TerminalBlock.astro';
import { t } from '../i18n/utils';
import { FORTALEZA_SIGNUP, FORTALEZA_DOCS } from '../config/links';
import esData from '../i18n/es.json';

const locale = 'es' as const;
const heroLines = esData.fortaleza.hero.terminal;

const nodes = Array.from({ length: 288 }, (_, i) => {
  const r = (Math.sin(i * 127.1) + 1) / 2;
  if (r > 0.975) return 'error';
  if (r > 0.95) return 'warn';
  return 'ok';
});
---

<BaseLayout
  locale={locale}
  title={t(locale, 'fortaleza.meta.title')}
  description={t(locale, 'fortaleza.meta.description')}
  path="/fortaleza"
>
  <!-- Hero -->
  <section class="px-margin-mobile md:px-margin-desktop py-16 grid-blueprint border-b border-outline-variant pt-32">
    <div class="max-w-max-width mx-auto flex flex-col md:flex-row items-center gap-unit-8">
      <div class="flex-1 space-y-unit-4">
        <div class="flex items-center gap-unit-2">
          <div class="inline-flex items-center gap-unit-2 px-unit-2 py-unit-1 bg-surface-container border border-outline-variant">
            <span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">security</span>
            <span class="font-mono-label text-primary text-xs">{t(locale, 'fortaleza.hero.version')}</span>
          </div>
          <span class="font-mono-label text-xs text-on-surface-variant border border-outline-variant px-2 py-1">
            {t(locale, 'fortaleza.hero.built_by')}
          </span>
        </div>
        <h1 class="font-bold text-[64px] md:text-[84px] leading-none tracking-tighter text-primary uppercase">
          {t(locale, 'fortaleza.hero.title')}
        </h1>
        <p class="font-headline-sm text-headline-sm text-on-surface-variant max-w-xl">
          {t(locale, 'fortaleza.hero.subtitle')}
        </p>
        <div class="flex flex-col sm:flex-row gap-unit-4 pt-unit-4">
          <a
            href={FORTALEZA_SIGNUP}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-primary text-on-primary px-unit-8 py-unit-4 font-mono-label font-bold hover:opacity-90 transition-all flex items-center justify-center gap-2"
          >
            {t(locale, 'fortaleza.hero.cta_try')}
            <span class="material-symbols-outlined text-base">open_in_new</span>
          </a>
          <a
            href={FORTALEZA_DOCS}
            target="_blank"
            rel="noopener noreferrer"
            class="border border-outline-variant px-unit-8 py-unit-4 font-mono-label text-on-surface hover:bg-surface-container transition-all flex items-center justify-center gap-2"
          >
            {t(locale, 'fortaleza.hero.cta_docs')}
            <span class="material-symbols-outlined text-base text-on-surface-variant">open_in_new</span>
          </a>
        </div>
      </div>
      <div class="flex-1 w-full">
        <TerminalBlock title="fortaleza@root: ~ /validation-stream" lines={heroLines} warnLine={3} />
      </div>
    </div>
  </section>

  <FortalezaScanners locale={locale} />
  <FortalezaCompliance locale={locale} />
  <DashboardMockup locale={locale} />
  <KanbanMockup locale={locale} />

  <!-- Attack Surface Map -->
  <section class="border-t border-outline-variant bg-surface-container overflow-hidden">
    <div class="px-unit-6 py-unit-4 border-b border-outline-variant flex justify-between items-center bg-surface-container-high">
      <div class="flex items-center gap-unit-2">
        <span class="material-symbols-outlined text-primary">hub</span>
        <span class="font-mono-label text-on-surface text-xs">{t(locale, 'fortaleza.map_section.title')}</span>
      </div>
      <span class="font-mono-code text-[10px] text-on-surface-variant">{t(locale, 'fortaleza.map_section.systems')}</span>
    </div>
    <div class="h-[360px] relative w-full bg-[#050505]">
      <div class="absolute inset-0 opacity-5 grid-blueprint"></div>
      <div class="grid grid-cols-[repeat(24,minmax(0,1fr))] gap-0.5 w-full opacity-40 p-2 absolute inset-0 overflow-hidden">
        {
          nodes.map((type) => (
            <div
              class:list={[
                'w-2 h-2 border border-white/5',
                type === 'error' && 'bg-error/60',
                type === 'warn' && 'bg-secondary/60',
                type === 'ok' && 'bg-primary/20',
              ]}
            />
          ))
        }
      </div>
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="text-center">
          <div class="font-mono-label text-primary text-lg mb-unit-2">
            {t(locale, 'fortaleza.map_section.scanning')} AS-882-PRD
          </div>
          <div class="h-1 w-64 bg-surface-container border border-outline-variant overflow-hidden mx-auto">
            <div class="h-full bg-primary w-1/3 animate-progress"></div>
          </div>
        </div>
      </div>
      <!-- Callout -->
      <div class="absolute bottom-8 left-8 p-unit-3 bg-surface-container border border-outline-variant shadow-lg glass-panel">
        <div class="font-mono-label text-primary text-[10px] mb-1">NODE DETECTED</div>
        <div class="font-mono-code text-[9px] text-on-surface-variant">IP: 192.168.1.104</div>
        <div class="font-mono-code text-[9px] text-on-surface-variant">PORTS: [80, 443, 22]</div>
        <div class="font-mono-code text-[9px] text-error">VULN: SSH_VER_EXPIRED</div>
      </div>
    </div>
  </section>

  <ExternalCTA locale={locale} />
</BaseLayout>
