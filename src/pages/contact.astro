---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { t } from '../i18n/utils';
import { CONTACT_MAILTO, CALENDLY_URL, FORTALEZA_SIGNUP } from '../config/links';
import esData from '../i18n/es.json';

const locale = 'es' as const;
const options = esData.contact.options;

const hrefMap: Record<string, string> = {
  email: CONTACT_MAILTO,
  schedule: CALENDLY_URL,
  fortaleza: FORTALEZA_SIGNUP,
};
---

<BaseLayout
  locale={locale}
  title={t(locale, 'contact.meta.title')}
  description={t(locale, 'contact.meta.description')}
  path="/contact"
>
  <!-- Hero -->
  <section class="px-margin-mobile md:px-margin-desktop pt-40 pb-16 border-b border-outline-variant grid-pattern">
    <div class="max-w-3xl">
      <SectionLabel text={t(locale, 'contact.hero.label')} />
      <h1 class="font-bold text-[48px] md:text-display-lg leading-none tracking-tighter mb-unit-4">
        {t(locale, 'contact.hero.title')}
      </h1>
      <p class="font-body-lg text-on-surface-variant max-w-xl">
        {t(locale, 'contact.hero.desc')}
      </p>
    </div>
  </section>

  <!-- Options -->
  <section class="px-margin-mobile md:px-margin-desktop py-16">
    <div class="max-w-max-width mx-auto grid grid-cols-1 md:grid-cols-3 gap-gutter">
      {
        options.map((opt) => (
          <div class="border border-outline-variant bg-surface-container-low p-unit-8 flex flex-col hover:border-primary/50 transition-colors">
            <h2 class="font-headline-sm text-headline-sm mb-unit-4">{opt.name}</h2>
            <p class="font-body-md text-on-surface-variant mb-auto">{opt.desc}</p>
            <a
              href={hrefMap[opt.id]}
              {...(opt.id !== 'email' ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              class="mt-unit-8 px-unit-6 py-unit-3 bg-primary text-on-primary font-mono-label font-bold text-center hover:opacity-90 transition-opacity"
            >
              {opt.cta}
            </a>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Terminal note -->
  <section class="px-margin-mobile md:px-margin-desktop py-16 border-t border-outline-variant bg-surface-container-lowest">
    <div class="max-w-max-width mx-auto flex flex-col items-center text-center gap-unit-4">
      <div class="font-mono-code text-on-surface-variant text-sm bg-background border border-outline-variant px-unit-8 py-unit-4 inline-block">
        {t(locale, 'contact.terminal_note')}
      </div>
      <p class="font-mono-label text-xs text-on-surface-variant">{t(locale, 'contact.response_note')}</p>
    </div>
  </section>
</BaseLayout>
