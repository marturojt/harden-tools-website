---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { t, localePath } from '../i18n/utils';
import { CALENDLY_URL } from '../config/links';
import esData from '../i18n/es.json';

const locale = 'es' as const;
const items = esData.services.items;
---

<BaseLayout
  locale={locale}
  title={t(locale, 'services.meta.title')}
  description={t(locale, 'services.meta.description')}
  path="/services"
>
  <!-- Hero -->
  <section class="px-margin-mobile md:px-margin-desktop pt-40 pb-16 border-b border-outline-variant grid-pattern">
    <div class="max-w-4xl">
      <SectionLabel text={t(locale, 'services.hero.label')} />
      <h1 class="font-bold text-[48px] md:text-display-lg leading-none tracking-tighter mb-unit-4">
        {t(locale, 'services.hero.title')}
      </h1>
      <p class="font-body-lg text-on-surface-variant max-w-2xl">
        {t(locale, 'services.hero.desc')}
      </p>
    </div>
  </section>

  <!-- Services detail -->
  <section class="px-margin-mobile md:px-margin-desktop py-16">
    <div class="max-w-max-width mx-auto space-y-0 divide-y divide-outline-variant">
      {
        items.map((item, i) => (
          <div class="py-16 grid grid-cols-1 md:grid-cols-12 gap-unit-8">
            <div class="md:col-span-4">
              <span class="font-mono-code text-primary text-sm mb-unit-2 block">0{i + 1}</span>
              <h2 class="font-headline-md text-headline-md mb-unit-2">{item.name}</h2>
              <span class="font-mono-label text-xs text-on-surface-variant border border-outline-variant px-2 py-1">
                {item.tag}
              </span>
            </div>
            <div class="md:col-span-8">
              <p class="font-headline-sm text-headline-sm text-on-surface-variant mb-unit-4">{item.short}</p>
              <p class="font-body-md text-on-surface-variant">{item.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <CTASection
    locale={locale}
    title={t(locale, 'services.cta.title')}
    terminalCmd="$ ssh operador@harden.tools --accion iniciar-engagement"
    ctaLabel={t(locale, 'services.cta.cta')}
    ctaHref={CALENDLY_URL}
  />
</BaseLayout>
